<Page x:Class="CarTripTracker.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="HomePage">
    <Grid Background="#F5F5F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20">
            <TextBlock Text="Нова поїздка" FontSize="28" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <Border Background="White" CornerRadius="8" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="270" Opacity="0.1" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <Label Content="Пункт призначення" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox x:Name="DestinationInput" Height="30" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

                    <Label Content="Поточний пробіг (км)" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox x:Name="MileageInput" Height="30" Margin="0,0,0,25" VerticalContentAlignment="Center"/>

                    <Button Content="Зберегти поїздку" Height="40" Background="#007ACC" 
                            Foreground="White" FontWeight="Bold" Click="SaveButton_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <TextBlock x:Name="InfoDisplay" Margin="0,20,0,0" HorizontalAlignment="Center" FontSize="14"/>
        </StackPanel>
    </Grid>
</Page>