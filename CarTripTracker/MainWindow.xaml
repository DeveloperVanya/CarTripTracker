<Page x:Class="CarTripTracker.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="HomePage">
    <Grid Background="#F0F0F0">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
            <TextBlock Text="Нова поїздка" Style="{StaticResource HeaderLabel}" HorizontalAlignment="Center"/>

            <Border Background="White" CornerRadius="10" Padding="20">
                <StackPanel>
                    <Label Content="Пункт призначення:"/>
                    <TextBox x:Name="DestinationInput"/>

                    <Label Content="Пробіг (км):"/>
                    <TextBox x:Name="MileageInput"/>

                    <Button Content="Зберегти" Click="SaveButton_Click"/>
                </StackPanel>
            </Border>

            <TextBlock x:Name="InfoDisplay" Margin="0,15" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>